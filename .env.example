NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ATENÇÃO — chave de servidor, NUNCA prefixar com NEXT_PUBLIC_.
# Usada exclusivamente pelo webhook de gateway (app/api/gateways/webhook/[integrationId])
# para gravar vendas sem uma sessão de usuário logado. Nunca é enviada ao navegador.
# Pegue em: Project Settings > API > Project API keys > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
